{
  "name": "commmitgpt",
  "version": "1.0.0",
  "description": "AI-Powered Intelligent Commit Message Generator with Semantic Analysis and Conventional Commits",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "commmitgpt": "dist/cli/index.js",
    "cgpt": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "precommit": "npm run lint && npm run test",
    "cli": "node dist/cli/index.js",
    "install-hook": "node scripts/install-hook.js"
  },
  "keywords": [
    "git",
    "commit",
    "conventional-commits",
    "ai",
    "machine-learning",
    "changelog",
    "semantic-analysis",
    "developer-tools",
    "automation"
  ],
  "author": "moggan1337",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moggan1337/CommitGPT.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "inquirer": "^9.2.12",
    "diff": "^5.1.0",
    "simple-git": "^3.21.0",
    "glob": "^10.3.10",
    "fuse.js": "^7.0.0",
    "ora": "^7.0.1",
    "conf": "^12.0.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "write-file-atomic": "^6.0.0",
    "read-file-atomic": "^4.0.2",
    "crypto-js": "^4.2.0",
    "semver": "^7.5.4",
    "treeify": "^1.1.0",
    "cli-table3": "^0.6.3",
    "marked": "^11.1.0",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/diff": "^5.0.8",
    "@types/inquirer": "^9.0.7",
    "@types/glob": "^8.1.0",
    "@types/crypto-js": "^4.2.1",
    "@types/semver": "^7.5.6",
    "@types/treeify": "^1.0.6",
    "@types/write-file-atomic": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2"
  }
}
